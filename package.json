{
  "name": "mediawiki-syntax-mcp",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/server.ts",
    "dev": "fastmcp dev src/server.ts",
    "lint": "prettier --check . && eslint . && tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write . && eslint --fix ."
  },
  "keywords": [
    "fastmcp",
    "mcp",
    "mediawiki",
    "syntax",
    "documentation"
  ],
  "repository": {
    "url": "https://github.com/kongyo2/mediawiki-syntax-mcp"
  },
  "author": "kongyo2",
  "homepage": "https://github.com/kongyo2/mediawiki-syntax-mcp",
  "type": "module",
  "license": "MIT",
  "description": "MediaWiki Syntax MCP Server - Provides comprehensive MediaWiki markup syntax documentation",
  "dependencies": {
    "axios": "^1.7.9",
    "axios-retry": "^4.5.0",
    "fastmcp": "^1.27.3",
    "p-retry": "^6.2.1",
    "zod": "^3.24.4",
    "zod-to-json-schema": "^3.24.6"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@modelcontextprotocol/inspector": "^0.16.4",
    "@tsconfig/node22": "^22.0.1",
    "@types/node": "^22.10.5",
    "eslint-config-prettier": "^10.1.3",
    "eslint-plugin-perfectionist": "^4.12.3",
    "jiti": "^2.4.2",
    "prettier": "^3.5.3",
    "semantic-release": "^24.2.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0",
    "vitest": "^3.1.3"
  }
}
